# Copy this file to .env and fill in values as needed.
# In the dev container, DB and Redis are pre-configured via docker-compose.
# Override here only if running outside the dev container.

# DATABASE_USERNAME=username
# DATABASE_PASSWORD=password
# DATABASE_HOST=localhost
# JWT_SECRET=your_jwt_secret_key_here
# NFSE_SCHEMAS_PATH=/absolute/path/to/.docs/references/schemas
# NFSE_CERT_PATH=/absolute/path/to/cert.pfx
# NFSE_CERT_PASSWORD=your_cert_password
# NFSE_API_URL=https://api.nfse.gov.br/nfse
